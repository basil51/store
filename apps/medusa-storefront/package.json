    "test:e2e:checkout": "playwright test e2e/checkout-*.spec.ts",
    "test:e2e:checkout-matrix": "playwright test e2e/checkout-deeplink-matrix.spec.ts",
    "test:e2e:checkout-happy-path": "playwright test e2e/checkout-happy-path.spec.ts"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
