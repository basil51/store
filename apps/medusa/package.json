{
  "name": "medusa",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "seed:locales": "medusa exec ./src/scripts/seed-locales.ts",
    "shipping:ensure-il": "medusa exec ./src/scripts/ensure-israel-shipping.ts",
    "stripe:sync-provider": "medusa exec ./src/scripts/sync-stripe-payment-provider.ts",
    "stripe:verify": "medusa exec ./src/scripts/verify-stripe-readiness.ts",
    "stripe:verify-order": "medusa exec ./src/scripts/verify-stripe-order-completion.ts",
    "provision:tenant": "medusa exec ./src/scripts/provision-store-tenant.ts",
    "delete:tenant": "medusa exec ./src/scripts/delete-store-tenant.ts",
    "describe:tenants": "medusa exec ./src/scripts/describe-store-topology.ts",
    "audit:translations": "medusa exec ./src/scripts/audit-translation-coverage.ts",
    "smoke:test-uploads": "medusa exec ./src/scripts/smoke-test-uploads.ts",
    "preset:analytics": "medusa exec ./src/scripts/report-preset-analytics.ts",
    "verify:translations": "medusa exec ./src/scripts/verify-product-translations.ts",
    "start": "medusa start",
    "dev": "medusa develop -p 9244",
    "test:integration:http": "DB_HOST=localhost DB_PORT=5433 DB_USERNAME=medusa DB_PASSWORD=medusa TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "DB_HOST=localhost DB_PORT=5433 DB_USERNAME=medusa DB_PASSWORD=medusa TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@internationalized/date": "^3.12.1",
    "@medusajs/admin-sdk": "2.13.6",
    "@medusajs/admin-shared": "2.13.6",
    "@medusajs/cli": "2.13.6",
    "@medusajs/dashboard": "2.13.6",
    "@medusajs/draft-order": "2.13.6",
    "@medusajs/framework": "2.13.6",
    "@medusajs/medusa": "2.13.6",
    "@medusajs/payment-stripe": "2.13.6",
    "@medusajs/ui": "4.1.6"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.6",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.12.4"
}