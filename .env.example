# Copy to .env and adjust. Used by local Medusa / Next when not using Docker for apps.

# Compose maps Postgres to host 5433 when 5432 is already taken locally
DATABASE_URL=postgresql://medusa:medusa@localhost:5433/medusa
REDIS_URL=redis://localhost:6380

# MinIO (S3-compatible) — public object URL prefix (path-style bucket in path)
S3_ENDPOINT=http://127.0.0.1:9100
S3_FILE_URL=http://127.0.0.1:9100/medusa
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345678
S3_BUCKET=medusa
S3_REGION=us-east-1

# Traefik: use your existing instance; attach app containers to the external
# Docker network named "traefik" (see docker-compose.yml). Adjust `name:` there
# if your network uses another name (`docker network ls`).

# Local Medusa dev uses port 9244 (see apps/medusa/package.json) to avoid clashes
# with common 9000/9001 services. Point apps/medusa-storefront/.env.local
# MEDUSA_BACKEND_URL at the same host:port.
